{
  "tests": [
    {
      "model": "PythonTestingLib.Examples.SimpleRamp",
      "source": "../../Examples/SimpleRamp.py",
      "variables": ["x"],
      "simulation": {
        "stop_time": 5.0,
        "tolerance": 1e-6
      }
    },
    {
      "model": "PythonTestingLib.Examples.ConstantCsv",
      "source": "../../Examples/ConstantCsv.py",
      "variables": ["x"],
      "simulation": {
        "stop_time": 5.0,
        "tolerance": 1e-6
      },
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "range",
            "min_value": 0.99,
            "max_value": 1.01
          }
        }
      }
    },
    {
      "model": "PythonTestingLib.Examples.PointsCheck",
      "source": "../../Examples/PointsCheck.py",
      "variables": ["x"],
      "simulation": {
        "stop_time": 10.0,
        "tolerance": 1e-6
      },
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "points",
            "points": [
              {"time": 0.0, "tolerance": 0.001, "tolerance_mode": "abs"},
              {"time": 1.5707963267948966, "value": 1.0, "tolerance": 0.05, "tolerance_mode": "rel"},
              {"time": 3.141592653589793, "tolerance": 0.02, "tolerance_mode": "abs", "time_tolerance": 0.05},
              {"time": 4.71238898038469, "value": -1.0, "tolerance": 0.05, "tolerance_mode": "rel"},
              {"time": 10.0, "tolerance": 0.01, "tolerance_mode": "abs"}
            ]
          }
        }
      }
    }
  ]
}
