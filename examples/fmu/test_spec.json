{
  "tests": [
    {
      "model": "BouncingBall",
      "fmu": "reference-fmus-binaries/2.0/BouncingBall.fmu",
      "variables": ["h", "v"],
      "simulation": {
        "stop_time": 3.0,
        "tolerance": 1e-6
      },
      "metrics": {
        "combinator": "and",
        "children": [
          {"metric": "nrmse", "variable": "h", "tolerance": 1e-3},
          {"metric": "nrmse", "variable": "v", "tolerance": 1e-3},
          {"metric": "range", "variable": "h", "min": -0.01, "max": 1.1},
          {"combinator": "warn", "children": [
            {"metric": "nrmse", "variable": "h", "against": "experiment", "tolerance": 0.2}
          ]}
        ]
      }
    },
    {
      "model": "Dahlquist",
      "fmu": "reference-fmus-binaries/2.0/Dahlquist.fmu",
      "variables": ["x"],
      "simulation": {
        "stop_time": 10.0,
        "tolerance": 1e-6
      },
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "points",
            "points": [
              {"time": 0.0, "value": 1.0, "tolerance": 0.001, "tolerance_mode": "abs"},
              {"time": 1.0, "tolerance": 0.05, "tolerance_mode": "rel"},
              {"time": 2.0, "tolerance": 0.05, "tolerance_mode": "rel", "time_tolerance": 0.05},
              {"time": 5.0, "tolerance": 0.001, "tolerance_mode": "abs"},
              {"time": 10.0, "tolerance": 0.0001, "tolerance_mode": "abs"}
            ]
          }
        }
      }
    },
    {
      "model": "VanDerPol",
      "fmu": "reference-fmus-binaries/2.0/VanDerPol.fmu",
      "variables": ["x0", "x1"],
      "simulation": {
        "stop_time": 20.0,
        "tolerance": 1e-6
      }
    }
  ]
}
