{
  "tests": [
    {
      "model": "ModelicaTestingLib.Examples.NoUnitTest",
      "variables": ["x"],
      "simulation": {
        "stop_time": 5,
        "tolerance": 1e-4
      }
    },
    {
      "model": "ModelicaTestingLib.Examples.TubeToleranceTest",
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "tube",
            "tube_width_mode": "rel",
            "tube_rel": 0.05
          }
        }
      }
    },
    {
      "model": "ModelicaTestingLib.Examples.FrequencyTest",
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "dominant-frequency",
            "peaks": [
              {"freq": 1.0, "tolerance": 0.15, "tolerance_mode": "rel"}
            ]
          }
        }
      }
    },
    {
      "model": "ModelicaTestingLib.Examples.MultiFrequencyTest",
      "comparison": {
        "variable_overrides": {
          "y": {
            "mode": "dominant-frequency",
            "peaks": [
              {"freq": 1.0, "tolerance": 0.15, "tolerance_mode": "rel"},
              {"freq": 3.0, "tolerance": 0.1, "tolerance_mode": "rel"},
              {"freq": 7.0, "tolerance": 0.05, "tolerance_mode": "rel"}
            ]
          }
        }
      }
    },
    {
      "model": "ModelicaTestingLib.Examples.MetricTreeTest",
      "metrics": {
        "combinator": "and",
        "children": [
          {"metric": "nrmse", "variable": "x", "tolerance": 1e-3},
          {
            "combinator": "warn",
            "children": [
              {"metric": "nrmse", "variable": "y", "tolerance": 1e-3}
            ]
          }
        ]
      }
    },
    {
      "model": "ModelicaTestingLib.Examples.RangeCheckTest",
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "range",
            "min_value": -1.05,
            "max_value": 1.05
          }
        }
      }
    },
    {
      "model": "ModelicaTestingLib.Examples.PointsCheckTest",
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "points",
            "points": [
              {"time": 0.0, "tolerance": 0.001, "tolerance_mode": "abs"},
              {"time": 1.5707963267948966, "value": 1.0, "tolerance": 0.05, "tolerance_mode": "rel"},
              {"time": 3.141592653589793, "tolerance": 0.02, "tolerance_mode": "abs", "time_tolerance": 0.05},
              {"time": 4.71238898038469, "value": -1.0, "tolerance": 0.05, "tolerance_mode": "rel"},
              {"time": 10.0, "tolerance": 0.01, "tolerance_mode": "abs"}
            ]
          }
        }
      }
    }
  ]
}
