{
  "tests": [
    {
      "model": "JuliaMtkExamples.SimpleRamp",
      "source": "simple_ramp.jl",
      "variables": ["x"],
      "simulation": {
        "stop_time": 5.0,
        "tolerance": 1e-6
      }
    },
    {
      "model": "JuliaMtkExamples.Frequency",
      "source": "frequency.jl",
      "variables": ["x"],
      "simulation": {
        "stop_time": 4.0,
        "tolerance": 1e-6
      },
      "comparison": {
        "variable_overrides": {
          "x": {
            "mode": "dominant-frequency",
            "peaks": [
              {"freq": 1.0, "tolerance": 0.15, "tolerance_mode": "rel"}
            ]
          }
        }
      }
    }
  ]
}
