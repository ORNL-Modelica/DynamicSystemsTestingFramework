# Keep test fixture results (override above exclusions)
!tests/fixtures/results/**/*.mat
!tests/fixtures/results/**/dslog.txt
!tests/fixtures/results/**/dsin.txt
!tests/fixtures/results/**/dsfinal.txt
!tests/fixtures/results_openmodelica/**/*.mat

# Simulation output (generated by the tool)
testing_output/

# Generated reports (dashboard.html, interactive plots, comparison_data.json)
reports/

# Reference-FMUs binaries (fetched by scripts/fetch_reference_fmus.py)
examples/fmu/reference-fmus-binaries/

