# Python
__pycache__/
*.py[codz]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
.env

# uv
# uv.lock is committed for reproducibility

# Dymola artifacts
*.mat
dslog.txt
dsin.txt
dsfinal.txt
buildlog.txt
dymosim
dymosim.exe
dymosim.exp
dymosim.lib
dymosim.dll
